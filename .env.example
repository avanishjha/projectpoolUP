# ============================================================================
# CONQR environment template — copy to .env (git-ignored) and fill in.
# ============================================================================

# ── Mobile app (Expo). EXPO_PUBLIC_* is embedded in the app bundle — ONLY
#    ever put the URL and the anon/publishable key here. Never secrets.
#    Local values come from `supabase status`.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Edge Function secrets. NEVER in the app, NEVER committed.
#    Local: supabase/functions/.env  ·  Cloud: `supabase secrets set KEY=value`
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MSG91_AUTH_KEY=
GUPSHUP_API_KEY=
CRONITOR_API_KEY=
SENTRY_DSN=
