    "format": "prettier --write .",
    "gen:authz-seed": "pnpm --filter @conqr/authz gen:sql-seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
