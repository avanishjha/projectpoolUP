{
  "name": "conqr",
  "version": "0.1.0",
  "private": true,
  "description": "CONQR — accountability challenges with real-money stakes. India-first.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
